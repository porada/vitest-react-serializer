{
	"name": "vitest-react-serializer",
	"version": "1.0.5",
	"description": "Serialize React components into formatted HTML",
	"license": "MIT",
	"author": {
		"name": "Dom Porada",
		"email": "dom@dom.engineering",
		"url": "https://dom.engineering"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/porada/vitest-react-serializer.git"
	},
	"keywords": [
		"component-testing",
		"html",
		"jsx",
		"react",
		"serializer",
		"snapshot",
		"snapshot-testing",
		"vitest"
	],
	"files": [
		"dist/**"
	],
	"type": "module",
	"sideEffects": false,
	"exports": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"engines": {
		"node": ">=20"
	},
	"packageManager": "pnpm@10.33.0",
	"dependencies": {
		"@prettier/sync": "^0.6.1",
		"prettier": "~3.8.1"
	},
	"peerDependencies": {
		"react": ">=19",
		"react-dom": ">=19",
		"vitest": ">=4"
	},
	"devDependencies": {
		"@standard-config/eslint": "^2.1.0",
		"@standard-config/oxlint": "^1.6.2",
		"@standard-config/prettier": "^1.12.0",
		"@standard-config/tsconfig": "^3.1.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitest/coverage-v8": "^4.1.3",
		"eslint": "^10.2.0",
		"publint": "^0.3.18",
		"react": "^19.2.5",
		"react-dom": "^19.2.4",
		"typescript": "^6.0.2",
		"vite-plus": "^0.1.16",
		"vitest": "^4.1.3"
	},
	"scripts": {
		"build": "vp pack",
		"fix": "pnpm format && pnpm lint && pnpm format",
		"format": "prettier --ignore-unknown --log-level=warn --write .",
		"format:check": "prettier --check --ignore-unknown .",
		"lint": "vp lint --fix",
		"lint:check": "vp lint --deny-warnings --type-check",
		"prepack": "pnpm run '/^(format:check|lint:check|test|typecheck)$/' && pnpm build",
		"prepare": "vp config",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	}
}
